PROFILE_STEPS="preflight packages ssh hostname user wsl_user sudo shell_env vim finalize"
CREATE_USER=1
ENABLE_TEMP_SUDO=1
ENABLE_VIM=ask
VIM_MODE=full
INSTALL_VIM_PLUGINS=1
STARSHIP_PRESET=bare-metal
VISUAL_HOSTNAME_ONLY=0
RESTART_SSH=1
CHANGE_DEFAULT_SHELL=1
FINAL_ACTION=su
APT_FIX_BROKEN=1
APT_UPGRADE=1
BASE_PACKAGES="wget curl unzip jq git zsh gcc g++ glibc-doc autojump universal-ctags ca-certificates sudo locales"
