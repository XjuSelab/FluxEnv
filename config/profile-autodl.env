PROFILE_STEPS="preflight packages ssh hostname user sudo shell_env vim finalize"
CREATE_USER=0
ENABLE_TEMP_SUDO=0
ENABLE_VIM=1
VIM_MODE=minimal
INSTALL_VIM_PLUGINS=0
STARSHIP_PRESET=docker
VISUAL_HOSTNAME_ONLY=1
RESTART_SSH=0
CHANGE_DEFAULT_SHELL=1
FINAL_ACTION=zsh
APT_FIX_BROKEN=0
APT_UPGRADE=0
BASE_PACKAGES="wget curl unzip jq git zsh gcc g++ autojump nano vim ca-certificates sudo locales"
